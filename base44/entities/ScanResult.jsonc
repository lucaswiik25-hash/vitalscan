{
  "name": "ScanResult",
  "type": "object",
  "rls": {
    "create": true,
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  },
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "food",
        "skincare",
        "supplement"
      ]
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "image_url": {
      "type": "string"
    },
    "product_name": {
      "type": "string"
    },
    "brand": {
      "type": "string"
    },
    "result_data": {
      "type": "object",
      "description": "Full analysis result JSON"
    },
    "safety_score": {
      "type": "number"
    },
    "quality_score": {
      "type": "number"
    },
    "verdict": {
      "type": "string"
    }
  },
  "required": [
    "type",
    "date"
  ]
}