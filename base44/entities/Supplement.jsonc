{
  "name": "Supplement",
  "type": "object",
  "rls": {
    "create": true,
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  },
  "properties": {
    "name": {
      "type": "string"
    },
    "dose": {
      "type": "string"
    },
    "unit": {
      "type": "string"
    },
    "time_of_day": {
      "type": "string",
      "enum": [
        "morning",
        "afternoon",
        "evening",
        "with_food"
      ],
      "default": "morning"
    },
    "taken_today": {
      "type": "boolean",
      "default": false
    },
    "last_taken_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "name"
  ]
}